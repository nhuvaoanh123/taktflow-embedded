services:
  # --- vcan0 setup (runs once, exits) ---
  can-setup:
    image: ubuntu:22.04
    command: >
      /bin/sh -c "
        apt-get update -qq && apt-get install -y -qq iproute2 > /dev/null 2>&1;
        if ip link show vcan0 > /dev/null 2>&1; then
          ip link set vcan0 up;
          echo '[can-setup] vcan0 already existed — set UP';
        elif ip link add vcan0 type vcan; then
          ip link set vcan0 up;
          echo '[can-setup] created vcan0 — set UP';
        else
          echo '[can-setup] ERROR: cannot create vcan0 — vcan module not loaded';
          echo '[can-setup] Run on host: sudo modprobe vcan';
          exit 1;
        fi
      "
    cap_add:
      - NET_ADMIN
      - NET_RAW
      - SYS_MODULE
    volumes:
      - /lib/modules:/lib/modules:ro
    network_mode: host
    restart: "no"

  # --- {{ ecu.name_upper }} ECU ---
  {{ ecu.name }}:
    build:
      context: .
      dockerfile: Dockerfile.customer
    network_mode: host
    cap_add:
      - NET_ADMIN
      - NET_RAW
    depends_on:
      can-setup:
        condition: service_completed_successfully
    environment:
      - CAN_INTERFACE=vcan0
    restart: unless-stopped
