    shutdown_requested = 1u;
}

/* ==================================================================
 * Main Entry Point
 * ================================================================== */

int main(void)
{
    shutdown_requested = 0u;

    /* Register signal handlers for graceful shutdown */
    (void)signal(SIGINT, {{ ecu.name_pascal }}_SignalHandler);
    (void)signal(SIGTERM, {{ ecu.name_pascal }}_SignalHandler);

    /* BSW module initialization (order matters) */
    Can_Init(&can_config);
    CanIf_Init(&canif_config);
    PduR_Init(&{{ ecu.name }}_pdur_config);
    Com_Init(&{{ ecu.name }}_com_config);
    Dem_Init(NULL_PTR);
    Rte_Init(&{{ ecu.name }}_rte_config);

    /* Generated Com bridge init */
    Swc_{{ ecu.name_pascal }}Com_Init();

    /* Customer SWC initialization */
{% for r in ecu.runnables if r.init_func %}
    {{ r.init_func }}();
{% endfor %}

    /* Start CAN controller */
    (void)Can_SetControllerMode(0u, CAN_CS_STARTED);

    (void)fprintf(stderr, "[{{ ecu.name_upper }}] BSW init complete — entering main loop\n");

    /* Main loop — 10ms tick via usleep */
    while (shutdown_requested == 0u) {
        (void)usleep(10000u);
        Rte_MainFunction();
    }

    /* Graceful shutdown */
    (void)Can_SetControllerMode(0u, CAN_CS_STOPPED);
    (void)fprintf(stderr, "[{{ ecu.name_upper }}] Shutdown complete\n");

    return 0;
}
