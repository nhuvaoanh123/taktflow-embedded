sil.taktflow-systems.com {
    # SIL — local VPS services
    reverse_proxy /ws/telemetry localhost:8080
    reverse_proxy /api/sap/* localhost:8090
    reverse_proxy /api/fault/* localhost:8091
    reverse_proxy /api/test/* localhost:8091

    # HIL — Raspberry Pi (strip /hil prefix before forwarding)
    handle_path /hil/* {
        reverse_proxy localhost:8081
    }

    redir / https://taktflow-systems.com/embedded permanent
}
